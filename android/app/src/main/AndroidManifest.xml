<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- FND-08: TTS foreground service permissions (declared now, used in Phase 4).
         Phase 1 declares them but does NOT request runtime permissions or start the
         service — that's Phase 4 scope. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />

    <!-- Notification channel for media playback (API 33+). Runtime request happens in
         Phase 4 when audio_service actually posts a lock-screen media notification. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- INTENTIONALLY NOT DECLARED:
         - READ_MEDIA_AUDIO / READ_EXTERNAL_STORAGE: murmur imports EPUBs via SAF
           (Storage Access Framework) through file_picker's ACTION_OPEN_DOCUMENT,
           not via MediaStore. Declaring READ_MEDIA_AUDIO would be a false permission
           over-request and a Play Store data-access declaration we don't need.
         - INTERNET: Phase 4 will add this for the one-time Kokoro model download.
           Phase 1 has no network calls.
         See 01-RESEARCH.md §Example 4 critical note. -->

    <application
        android:label="Murmur"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher">

        <!-- NOTE: audio_service `<service>` stanza is NOT declared in Phase 1. Plan 03
             defers it to Phase 4 where audio_service actually lives in pubspec.yaml.
             Declaring it now with no backing package causes manifest-merger warnings
             for no benefit. See 01-RESEARCH.md §Example 4. -->

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <meta-data
                android:name="io.flutter.embedding.android.NormalTheme"
                android:resource="@style/NormalTheme" />
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- LIB-02 / D-14: accept EPUBs from file browsers via VIEW intents
                 (Files, Downloads, third-party file managers). Scheme set to
                 content + file so both SAF URIs and raw file paths resolve. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="content" />
                <data android:scheme="file" />
                <data android:mimeType="application/epub+zip" />
            </intent-filter>

            <!-- LIB-02 / D-14: single-file Share target for EPUBs. Triggered
                 by other apps' "Share → Murmur" action. -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="application/epub+zip" />
            </intent-filter>

            <!-- LIB-02 / D-14: multi-file Share target. Files app and some
                 file managers use SEND_MULTIPLE for batch shares. -->
            <intent-filter>
                <action android:name="android.intent.action.SEND_MULTIPLE" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="application/epub+zip" />
            </intent-filter>
        </activity>

        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>
</manifest>
